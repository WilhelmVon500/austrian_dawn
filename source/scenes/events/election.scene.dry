{!<tr><td><div class="box" style='background-color:#FA5A42'> </div> !} AP: {!</td><td>!} [+ ap_votes +] {!</td><td>!} [+ votes_change_ap +] {!</td><td>!} [+ ap_seats +] ([+ ap_b +]%) {!</td><td>!} [+ str_seats_change_ap +] ([+ str_change_ap +]%) {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#0E428E'> </div> !} DNLP: {!</td><td>!} [+ dnlp_votes +] {!</td><td>!} [+ votes_change_dnlp +] {!</td><td>!} {!</td><td>!} [+ dnlp_seats +] ([+ dnlp_b +]%) {!</td><td>!} [+ str_seats_change_dnlp +] ([+ str_change_dnlp +]%) {!</td></tr>!}

[? if ovp_exist: {!<tr><td><div class="box" style='background-color:#000000'> </div> !} ÖVP: {!</td><td>!} [+ ovp_votes +] {!</td><td>!} [+ votes_change_ovp +] {!</td><td>!} {!</td><td>!} [+ ovp_seats +] ([+ ovp_b +]%) {!</td><td>!} [+ str_seats_change_ovp +] ([+ str_change_ovp +]%) {!</td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#ED2939'> </div> !} VF: {!</td><td>!} [+ vf_votes +] {!</td><td>!} [+ votes_change_vf +] {!</td><td>!} {!</td><td>!} [+ vf_seats +] ([+ vf_b +]%) {!</td><td>!} [+ str_seats_change_vf +] ([+ str_change_vf +]%) {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#909090'> </div> !} Other: {!</td><td>!} [+ other_votes +] {!</td><td>!} [+ votes_change_other +] {!</td><td>!} {!</td><td>!} [+ other_seats +] ([+ other_b +]%) {!</td><td>!} [+ str_seats_change_other +] ([+ str_change_other +]%) {!</td></tr>!}
{!</table>!}

