- @governor


@oclk_majority
title: We can form a majority government!
subtitle: <span style="color: #EEEE22;">**[+ oclk_name +]**</span> ([+ oclk_zl +]%)
view-if: oclk_seats_salzburg > 15
on-arrival: {!
Q.salzburg_oclk = 1;
Q.salzburg_vf = 0;

Q.in_right_coalition_salzburg = 0;
Q.in_vf_majority_salzburg = 0;
Q.in_oclk_majority_salzburg = 1;
!}

