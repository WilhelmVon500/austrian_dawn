- @governor


@right_coalition
title: We can form a right-wing coalition.
subtitle: <span style="color: #EEEE22;">**[+ oclk_name +]**</span> + <span style="color: #ED2939;">**VF**</span>[? if ovp_exist: + <span style="color: #000000;">**ÖVP**</span>?] ([+ right_coalition_salzburg +]%)
view-if: right_coalition_salzburg > 50
on-arrival: {!
Q.salzburg_oclk = 1;
Q.salzburg_vf = 1;

Q.in_right_coalition_salzburg = 1;
Q.in_vf_majority_salzburg = 0;
Q.in_oclk_majority_salzburg = 0;
!}

