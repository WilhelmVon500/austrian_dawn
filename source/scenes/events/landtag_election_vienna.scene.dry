{!<tr><td><div class="box" style='background-color:#ED2939'> </div> !} VF: {!</td><td>!} [+ vf_election_votes_vienna +]% {!</td><td>!} [+ vf_seats_vienna +] ([+ vf_wl +]%) {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#909090'> </div> !} Other: {!</td><td>!} [+ other_election_votes_vienna +]% {!</td><td>!} [+ other_seats_vienna +] ([+ other_wl +]%) {!</td></tr>!}
